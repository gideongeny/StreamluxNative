<resources>
    <style name="Theme.StreamLux" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0f172a</item>
        <item name="android:navigationBarColor">#020617</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="Theme.StreamLux.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@drawable/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_streamlux</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.StreamLux</item>
    </style>
</resources>
